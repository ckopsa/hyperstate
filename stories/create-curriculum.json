{
  "name": "create-curriculum",
  "base_url": "http://localhost:8000",
  "steps": [
    {
      "method": "GET",
      "url": "/curricula",
      "body": null,
      "status_code": 200,
      "response_title": "Curricula"
    },
    {
      "method": "POST",
      "url": "/curricula",
      "body": {
        "name": "3rd Grade Math Foundations",
        "description": "Core arithmetic and geometry for 3rd grade",
        "grade_level": "3rd"
      },
      "status_code": 200,
      "response_title": "3rd Grade Math Foundations"
    },
    {
      "method": "POST",
      "url": "{self}/items",
      "body": {
        "subject_id": "SUB-MATH",
        "title": "Place Value and Number Sense",
        "description": "Understanding hundreds, tens, and ones",
        "day_offset": 1
      },
      "status_code": 200,
      "response_title": "3rd Grade Math Foundations"
    },
    {
      "method": "POST",
      "url": "{self}/items",
      "body": {
        "subject_id": "SUB-READ",
        "title": "Phonics and Decoding Strategies",
        "description": "Blending consonant clusters and digraphs",
        "day_offset": 2
      },
      "status_code": 200,
      "response_title": "3rd Grade Math Foundations"
    },
    {
      "method": "POST",
      "url": "{self}/items/reorder",
      "body": {
        "item_ids": "{response:sections.1.items.1.data.id},{response:sections.1.items.0.data.id}"
      },
      "status_code": 200,
      "response_title": "3rd Grade Math Foundations",
      "assertions": [
        {
          "type": "value_equals",
          "path": "sections.1.items.0.data.title",
          "value": "Phonics and Decoding Strategies"
        },
        {
          "type": "value_equals",
          "path": "sections.1.items.1.data.title",
          "value": "Place Value and Number Sense"
        }
      ]
    },
    {
      "method": "POST",
      "url": "{self}/instantiate",
      "body": {
        "student_id": "STU-DEMO",
        "start_date": "2026-04-07"
      },
      "status_code": 200,
      "response_title": "Lessons",
      "assertions": [
        {
          "type": "value_equals",
          "path": "flash.type",
          "value": "success"
        },
        {
          "type": "value_equals",
          "path": "sections.1.items.0.data.title",
          "value": "Place Value and Number Sense"
        },
        {
          "type": "value_equals",
          "path": "sections.1.items.0.data.scheduled_date",
          "value": "2026-04-08"
        },
        {
          "type": "value_equals",
          "path": "sections.1.items.1.data.title",
          "value": "Phonics and Decoding Strategies"
        },
        {
          "type": "value_equals",
          "path": "sections.1.items.1.data.scheduled_date",
          "value": "2026-04-09"
        }
      ]
    },
    {
      "method": "GET",
      "url": "nav:parent",
      "body": null,
      "status_code": 200,
      "response_title": "Daily Dashboard"
    }
  ],
  "created_at": "2026-03-16T18:00:00"
}
