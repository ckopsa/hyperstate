{
  "name": "create-curriculum",
  "base_url": "http://localhost:8000",
  "steps": [
    {
      "method": "GET",
      "url": "/curricula",
      "response_title": "Curricula"
    },
    {
      "action": "create-curriculum",
      "body": {
        "name": "3rd Grade Math Foundations",
        "description": "Core arithmetic and geometry for 3rd grade",
        "grade_level": "3rd"
      },
      "response_title": "3rd Grade Math Foundations"
    },
    {
      "action": "add-item",
      "body": {
        "subject_id": "SUB-MATH",
        "title": "Place Value and Number Sense",
        "description": "Understanding hundreds, tens, and ones",
        "day_offset": 1
      },
      "response_title": "3rd Grade Math Foundations"
    },
    {
      "action": "add-item",
      "body": {
        "subject_id": "SUB-READ",
        "title": "Phonics and Decoding Strategies",
        "description": "Blending consonant clusters and digraphs",
        "day_offset": 2
      },
      "response_title": "3rd Grade Math Foundations"
    },
    {
      "action": "reorder-items",
      "body": {
        "item_ids": "{response:sections.1.items.1.data.id},{response:sections.1.items.0.data.id}"
      },
      "response_title": "3rd Grade Math Foundations",
      "assertions": [
        {
          "type": "value_equals",
          "path": "sections.1.items.0.data.title",
          "value": "Phonics and Decoding Strategies"
        },
        {
          "type": "value_equals",
          "path": "sections.1.items.1.data.title",
          "value": "Place Value and Number Sense"
        }
      ]
    },
    {
      "action": "edit-item",
      "item": 0,
      "body": {
        "subject_id": "SUB-READ",
        "title": "Advanced Phonics",
        "description": "Advanced consonant clusters and digraphs",
        "day_offset": 3
      },
      "response_title": "3rd Grade Math Foundations",
      "assertions": [
        {
          "type": "value_equals",
          "path": "flash.title",
          "value": "Item Updated"
        },
        {
          "type": "value_equals",
          "path": "sections.1.items.0.data.title",
          "value": "Advanced Phonics"
        },
        {
          "type": "value_equals",
          "path": "sections.1.items.0.data.day_offset",
          "value": "+3"
        }
      ]
    },
    {
      "action": "remove-item",
      "item": 1,
      "body": {},
      "response_title": "3rd Grade Math Foundations",
      "assertions": [
        {
          "type": "value_equals",
          "path": "flash.title",
          "value": "Item Removed"
        },
        {
          "type": "value_equals",
          "path": "sections.1.items.0.data.title",
          "value": "Advanced Phonics"
        }
      ]
    },
    {
      "action": "instantiate-curriculum",
      "body": {
        "student_id": "STU-DEMO",
        "start_date": "2026-04-07"
      },
      "response_title": "Lessons",
      "assertions": [
        {
          "type": "value_equals",
          "path": "flash.type",
          "value": "success"
        },
        {
          "type": "value_equals",
          "path": "sections.1.items.0.data.title",
          "value": "Advanced Phonics"
        },
        {
          "type": "value_equals",
          "path": "sections.1.items.0.data.scheduled_date",
          "value": "2026-04-10"
        }
      ]
    },
    {
      "method": "GET",
      "url": "nav:parent",
      "response_title": "Daily Dashboard"
    }
  ],
  "created_at": "2026-03-16T18:00:00"
}
