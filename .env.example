# Copy to .env and adjust as needed. Defaults match docker-compose.yml.

# App service.
APP_PORT=8000
DATABASE_URL=postgresql+asyncpg://hyperstate:hyperstate@localhost:5432/mealplan

# Keycloak service and local admin console.
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# OIDC client imported by deploy/keycloak/realm-mealplan.json.
# For host-side local development, localhost points at the published Keycloak
# port. docker-compose.yml overrides OIDC_ISSUER to the keycloak service name
# inside the app container.
OIDC_ISSUER=http://localhost:8080/realms/mealplan
OIDC_CLIENT_ID=mealplan-app
OIDC_CLIENT_SECRET=mealplan-dev-secret
OIDC_REDIRECT_URI=http://localhost:8000/auth/callback

# Home Assistant calendar feed. Set to a long, random secret; the household
# subscribes Home Assistant's Remote Calendar to the cookieless URL
#   http://<host>:8000/calendar/feed/<FEED_TOKEN>.ics
# which aggregates every upcoming (non-completed) week's dinner prep reminders.
# A request whose token does not match is rejected with 404; leaving FEED_TOKEN
# unset disables the feed entirely.
FEED_TOKEN=change-me-to-a-long-random-secret
