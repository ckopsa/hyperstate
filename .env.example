# Copy to .env and adjust as needed. Matches the docker-compose Postgres service.
# Application database (mealplan).
DATABASE_URL=postgresql+asyncpg://hyperstate:hyperstate@localhost:5432/mealplan

# Keycloak database is also created by the compose init script (see
# deploy/postgres/init-databases.sql) and used by a later auth convoy:
# KEYCLOAK_DATABASE_URL=postgresql://hyperstate:hyperstate@localhost:5432/keycloak

# Home Assistant calendar feed. Set to a long, random secret; the household
# subscribes Home Assistant's Remote Calendar to the cookieless URL
#   http://<host>:8000/calendar/feed/<FEED_TOKEN>.ics
# which aggregates every upcoming (non-completed) week's dinner prep reminders.
# A request whose token does not match is rejected with 404; leaving FEED_TOKEN
# unset disables the feed entirely.
FEED_TOKEN=change-me-to-a-long-random-secret
